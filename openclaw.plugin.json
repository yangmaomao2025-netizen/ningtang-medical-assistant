{
  "id": "medical-assistant",
  "name": "宁唐医学助手",
  "description": "OpenClaw 医学问答插件，支持多端客户端和统一后台管理",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "metadata": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "string" },
          "author": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "models": {
        "type": "object",
        "properties": {
          "minimax": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "apiKey": { "type": "string" },
              "endpoint": { "type": "string" },
              "model": { "type": "string" }
            }
          },
          "kimi": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "apiKey": { "type": "string" },
              "endpoint": { "type": "string" },
              "model": { "type": "string" }
            }
          },
          "glm": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "apiKey": { "type": "string" },
              "endpoint": { "type": "string" },
              "model": { "type": "string" }
            }
          }
        }
      },
      "defaultModel": { "type": "string", "enum": ["kimi", "minimax", "glm"] },
      "medical": {
        "type": "object",
        "properties": {
          "disclaimer": { "type": "string" },
          "confidence": {
            "type": "object",
            "properties": {
              "high": { "type": "number" },
              "medium": { "type": "number" }
            }
          },
          "urgentKeywords": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "sso": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean" },
          "providers": {
            "type": "object",
            "properties": {
              "oauth": { "type": "object" },
              "saml": { "type": "object" },
              "ldap": { "type": "object" }
            }
          }
        }
      },
      "database": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "uri": { "type": "string" },
          "encryption": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "key": { "type": "string" }
            }
          }
        }
      },
      "redis": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean" },
          "host": { "type": "string" },
          "port": { "type": "number" },
          "password": { "type": "string" },
          "db": { "type": "number" }
        }
      },
      "admin": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean" },
          "basePath": { "type": "string" },
          "sessionTimeout": { "type": "number" }
        }
      },
      "api": {
        "type": "object",
        "properties": {
          "basePath": { "type": "string" },
          "rateLimit": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "requestsPerMinute": { "type": "number" }
            }
          },
          "cors": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "origins": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      },
      "logging": {
        "type": "object",
        "properties": {
          "level": { "type": "string", "enum": ["debug", "info", "warn", "error"] },
          "auditLogEnabled": { "type": "boolean" }
        }
      }
    }
  },
  "uiHints": {
    "models.minimax.apiKey": { "sensitive": true },
    "models.kimi.apiKey": { "sensitive": true },
    "models.glm.apiKey": { "sensitive": true },
    "database.encryption.key": { "sensitive": true },
    "redis.password": { "sensitive": true }
  }
}
