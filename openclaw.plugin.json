{
  "id": "medical-assistant",
  "name": "宁唐医学助手",
  "description": "专业的医学问答助手插件，支持多端路由",
  "version": "1.0.0",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "openclaw": {
    "extensions": ["./src/index.ts"],
    "config": {
      "type": "object",
      "properties": {
        "apiKey": {
          "type": "string",
          "description": "LLM API Key"
        },
        "model": {
          "type": "string",
          "default": "kimi-k2.5",
          "description": "默认模型"
        },
        "baseUrl": {
          "type": "string",
          "description": "API Base URL"
        }
      }
    }
  }
}
